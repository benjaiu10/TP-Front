---
import Layout from '../layouts/Layout.astro';
---

<Layout title="GAME VAULT — Arcade Catalog">

  <!-- TICKER -->
  <div class="ticker-wrap" aria-hidden="true">
    <div class="ticker">
      <span>INSERT COIN</span><span>★</span>
      <span>PRESS START</span><span>★</span>
      <span>GAME VAULT</span><span>★</span>
      <span>HIGH SCORE</span><span>★</span>
      <span>PLAYER ONE</span><span>★</span>
      <span>INSERT COIN</span><span>★</span>
      <span>PRESS START</span><span>★</span>
      <span>GAME VAULT</span><span>★</span>
      <span>HIGH SCORE</span><span>★</span>
      <span>PLAYER ONE</span><span>★</span>
    </div>
  </div>

  <!-- HEADER -->
  <header class="site-header">
    <div class="container header-inner">
      <div class="logo-wrap">
        <p class="logo-sub">// ARCADE CATALOG //</p>
        <h1 class="logo glow-cyan">GAME<span class="glow-pink">VAULT</span></h1>
      </div>
      <div class="header-search">
        <input
          type="text"
          id="searchInput"
          class="search-input"
          placeholder="BUSCAR JUEGO..."
          autocomplete="off"
          spellcheck="false"
        />
        <span class="search-icon">⌕</span>
      </div>
    </div>
  </header>

  <!-- STATS BAR -->
  <div class="stats-bar">
    <div class="container stats-inner">
      <span class="stat-item">
        <span class="stat-label">JUEGOS</span>
        <span class="stat-val glow-cyan" id="statCount">—</span>
      </span>
      <span class="stat-sep">|</span>
      <span class="stat-item">
        <span class="stat-label">FUENTE</span>
        <span class="stat-val glow-pink">RAWG API</span>
      </span>
      <span class="stat-sep">|</span>
      <span class="stat-item">
        <span class="stat-label">ESTADO</span>
        <span class="stat-val" id="statStatus" style="color:var(--neon-yellow)">CARGANDO...</span>
      </span>
    </div>
  </div>

  <!-- CATÁLOGO -->
  <section class="section" id="catalogo">
    <div class="container">
      <div class="section-head">
        <h2 class="section-title"><span class="glow-pink">▌</span> TOP RATED</h2>
        <p class="section-sub">Los mejores juegos según Metacritic</p>
      </div>

      <div id="loadingState" class="loading-state">
        <p class="pixel-blink">CARGANDO JUEGOS...</p>
        <div class="loading-bar"><div class="loading-fill"></div></div>
      </div>

      <div id="errorState" class="error-box hidden">
        <p class="pixel-text">ERROR DE CONEXIÓN</p>
        <p style="color:var(--muted);margin-bottom:1rem;font-size:.9rem">No se pudo contactar la API de RAWG.</p>
        <button id="retryBtn" class="retry-btn">↺ REINTENTAR</button>
      </div>

      <div id="mainGrid" class="games-grid hidden"></div>
      <p id="noResults" class="no-results hidden">NO SE ENCONTRARON RESULTADOS</p>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container footer-inner">
      <p class="footer-logo glow-cyan">GAMEVAULT</p>
      <p class="footer-text">Datos por <a href="https://rawg.io" target="_blank" class="footer-link">RAWG.io API</a></p>
      <p class="footer-copy">© {new Date().getFullYear()} — PROYECTO FRONTEND</p>
    </div>
  </footer>

  <!-- MODAL -->
  <div id="modal" class="modal-overlay" role="dialog" aria-modal="true">
    <div class="modal-box">
      <button class="modal-close" id="modalClose">✕ CERRAR</button>
      <div class="modal-content" id="modalContent">
        <p class="pixel-blink" style="text-align:center;padding:3rem">CARGANDO...</p>
      </div>
    </div>
  </div>

</Layout>

<style>
  .ticker-wrap { overflow:hidden; background:var(--neon-pink); padding:5px 0; white-space:nowrap; }
  .ticker { display:inline-block; animation:marquee 20s linear infinite; white-space:nowrap; }
  .ticker span { font-family:var(--font-pixel); font-size:.45rem; color:#000; margin:0 1.5rem; letter-spacing:2px; }

  .site-header { border-bottom:1px solid var(--border); padding:20px 0; position:sticky; top:0; z-index:50; background:rgba(5,5,15,0.92); backdrop-filter:blur(12px); }
  .header-inner { display:flex; align-items:center; justify-content:space-between; gap:2rem; flex-wrap:wrap; }
  .logo-sub { font-family:var(--font-pixel); font-size:.4rem; color:var(--muted); letter-spacing:3px; margin-bottom:6px; }
  .logo { font-family:var(--font-pixel); font-size:clamp(1rem,3vw,1.6rem); letter-spacing:4px; color:var(--neon-cyan); animation:flicker 6s infinite; }
  .logo span { color:var(--neon-pink); }

  .header-search { position:relative; flex:1; max-width:420px; }
  .search-input { width:100%; background:var(--bg-card); border:1px solid var(--neon-cyan); border-radius:3px; color:var(--neon-cyan); font-family:var(--font-pixel); font-size:.55rem; padding:10px 40px 10px 14px; outline:none; letter-spacing:1px; box-shadow:0 0 10px rgba(0,245,255,.15); transition:box-shadow .2s; }
  .search-input::placeholder { color:var(--muted); }
  .search-input:focus { box-shadow:0 0 20px rgba(0,245,255,.35); }
  .search-icon { position:absolute; right:12px; top:50%; transform:translateY(-50%); color:var(--neon-cyan); font-size:1.1rem; pointer-events:none; }

  .stats-bar { border-bottom:1px solid var(--border); padding:8px 0; background:rgba(0,245,255,.03); }
  .stats-inner { display:flex; align-items:center; gap:1rem; flex-wrap:wrap; }
  .stat-item { display:flex; align-items:center; gap:8px; }
  .stat-label { font-family:var(--font-pixel); font-size:.38rem; color:var(--muted); letter-spacing:1px; }
  .stat-val { font-family:var(--font-pixel); font-size:.5rem; letter-spacing:1px; }
  .stat-sep { color:var(--border); font-size:1.2rem; }

  .section { padding:3rem 0; }
  .section-head { margin-bottom:1.8rem; }
  .section-title { font-family:var(--font-pixel); font-size:.7rem; letter-spacing:2px; color:var(--text); margin-bottom:8px; }
  .section-sub { font-size:.85rem; color:var(--muted); font-weight:500; }

  .loading-state { text-align:center; padding:4rem 2rem; }
  .pixel-blink { font-family:var(--font-pixel); font-size:.6rem; color:var(--neon-cyan); letter-spacing:2px; animation:blink 1s step-end infinite; margin-bottom:1.5rem; }
  .loading-bar { width:240px; height:8px; border:1px solid var(--neon-cyan); border-radius:4px; margin:0 auto; overflow:hidden; }
  .loading-fill { height:100%; width:0%; background:var(--neon-cyan); animation:loadProgress 2s ease forwards; box-shadow:0 0 8px var(--neon-cyan); }
  @keyframes loadProgress { to { width:90%; } }

  .error-box { border:1px solid var(--neon-pink); padding:2rem; text-align:center; box-shadow:0 0 20px rgba(255,45,120,.2); }
  .pixel-text { font-family:var(--font-pixel); font-size:.65rem; margin-bottom:1rem; color:var(--neon-pink); }
  .retry-btn { font-family:var(--font-pixel); font-size:.5rem; letter-spacing:1px; color:var(--neon-cyan); border:1px solid var(--neon-cyan); padding:8px 16px; border-radius:3px; background:transparent; cursor:pointer; transition:background .2s; }
  .retry-btn:hover { background:rgba(0,245,255,.1); }

  .games-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(260px,1fr)); gap:1.25rem; }

  .game-card { position:relative; background:var(--bg-card); border:1px solid var(--border); border-radius:4px; overflow:hidden; cursor:pointer; animation:fadeInUp .5s ease both; transition:border-color .2s, transform .2s, box-shadow .2s; }
  .game-card:hover { border-color:var(--neon-cyan); transform:translateY(-6px) scale(1.02); box-shadow:0 0 20px rgba(0,245,255,.2), 0 12px 40px rgba(0,0,0,.6); }
  .card-img-wrap { position:relative; aspect-ratio:16/9; overflow:hidden; background:#111; }
  .card-img-wrap img { width:100%; height:100%; object-fit:cover; filter:saturate(.8); transition:transform .4s, filter .4s; }
  .game-card:hover .card-img-wrap img { transform:scale(1.08); filter:saturate(1.2) brightness(.7); }
  .card-overlay { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; background:rgba(0,0,0,.5); opacity:0; transition:opacity .3s; }
  .game-card:hover .card-overlay { opacity:1; }
  .overlay-text { font-family:var(--font-pixel); font-size:.55rem; color:var(--neon-cyan); text-shadow:0 0 10px var(--neon-cyan); letter-spacing:2px; animation:blink 1s step-end infinite; }
  .card-score { position:absolute; top:8px; right:8px; font-family:var(--font-pixel); font-size:.6rem; padding:4px 7px; border:1px solid; border-radius:3px; background:rgba(5,5,15,.85); line-height:1; }
  .card-body { padding:12px 14px 14px; }
  .card-year { font-family:var(--font-pixel); font-size:.45rem; color:var(--muted); margin-bottom:6px; letter-spacing:1px; }
  .card-title { font-size:1rem; font-weight:700; line-height:1.3; margin-bottom:6px; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
  .card-genres { font-size:.78rem; color:var(--muted); font-weight:500; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

  .corner { position:absolute; width:10px; height:10px; opacity:0; transition:opacity .2s; }
  .game-card:hover .corner { opacity:1; }
  .corner.tl { top:3px; left:3px; border-top:2px solid var(--neon-cyan); border-left:2px solid var(--neon-cyan); }
  .corner.tr { top:3px; right:3px; border-top:2px solid var(--neon-cyan); border-right:2px solid var(--neon-cyan); }
  .corner.bl { bottom:3px; left:3px; border-bottom:2px solid var(--neon-cyan); border-left:2px solid var(--neon-cyan); }
  .corner.br { bottom:3px; right:3px; border-bottom:2px solid var(--neon-cyan); border-right:2px solid var(--neon-cyan); }

  .no-results { font-family:var(--font-pixel); font-size:.6rem; color:var(--neon-pink); text-align:center; padding:2rem; letter-spacing:2px; }

  .modal-overlay { display:none; position:fixed; inset:0; z-index:200; background:rgba(0,0,0,.88); backdrop-filter:blur(6px); align-items:center; justify-content:center; padding:1.5rem; }
  .modal-overlay.open { display:flex; }
  .modal-box { position:relative; background:var(--bg-card); border:1px solid var(--neon-cyan); box-shadow:0 0 40px rgba(0,245,255,.25); border-radius:4px; width:100%; max-width:780px; max-height:88vh; overflow-y:auto; animation:fadeInUp .25s ease; }
  .modal-close { position:absolute; top:14px; right:16px; font-family:var(--font-pixel); font-size:.5rem; color:var(--neon-pink); z-index:10; padding:6px 10px; border:1px solid var(--neon-pink); border-radius:3px; background:transparent; cursor:pointer; letter-spacing:1px; transition:background .15s; }
  .modal-close:hover { background:rgba(255,45,120,.15); }
  .modal-content { padding:1.8rem; }

  .site-footer { padding:2rem 0; border-top:1px solid var(--border); margin-top:3rem; }
  .footer-inner { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; }
  .footer-logo { font-family:var(--font-pixel); font-size:.65rem; letter-spacing:3px; }
  .footer-text, .footer-copy { font-size:.8rem; color:var(--muted); }
  .footer-link { color:var(--neon-cyan); }

  .hidden { display:none !important; }

  @media (max-width:640px) {
    .header-inner { flex-direction:column; align-items:flex-start; }
    .header-search { max-width:100%; width:100%; }
    .games-grid { grid-template-columns:repeat(auto-fill, minmax(200px,1fr)); }
  }
</style>

<script>
  const API_KEY = 'f9e6e3ef76c1465bba1984eeee28e3e1';
  let allGames = [];

  const mainGrid     = document.getElementById('mainGrid');
  const loadingState = document.getElementById('loadingState');
  const errorState   = document.getElementById('errorState');
  const noResults    = document.getElementById('noResults');
  const statCount    = document.getElementById('statCount');
  const statStatus   = document.getElementById('statStatus');
  const searchInput  = document.getElementById('searchInput');
  const retryBtn     = document.getElementById('retryBtn');
  const modal        = document.getElementById('modal');
  const modalClose   = document.getElementById('modalClose');
  const modalContent = document.getElementById('modalContent');

  function scoreColor(r) {
    return r >= 4 ? '#39ff14' : r >= 3 ? '#f5e642' : '#ff2d78';
  }

  function createCard(game, delay) {
    const score = game.rating ? game.rating.toFixed(1) : '?';
    const color = scoreColor(game.rating);
    const year  = game.released ? game.released.slice(0, 4) : '—';
    const card  = document.createElement('article');
    card.className = 'game-card';
    card.dataset.id = game.id;
    card.style.animationDelay = delay + 'ms';
    card.innerHTML = `
      <div class="card-img-wrap">
        <img src="${game.image}" alt="${game.title}" loading="lazy" />
        <div class="card-overlay"><span class="overlay-text">▶ VER MÁS</span></div>
        <div class="card-score" style="color:${color};border-color:${color};box-shadow:0 0 8px ${color}44">${score}</div>
      </div>
      <div class="card-body">
        <p class="card-year">${year}</p>
        <h3 class="card-title">${game.title}</h3>
        <p class="card-genres">${game.genres}</p>
      </div>
      <span class="corner tl"></span><span class="corner tr"></span>
      <span class="corner bl"></span><span class="corner br"></span>
    `;
    card.addEventListener('click', () => openModal(game.id));
    return card;
  }

  function renderGames(games) {
    mainGrid.innerHTML = '';
    noResults.classList.toggle('hidden', games.length > 0);
    games.forEach((g, i) => mainGrid.appendChild(createCard(g, i * 50)));
    statCount.textContent = games.length;
  }

  async function loadGames() {
    loadingState.classList.remove('hidden');
    errorState.classList.add('hidden');
    mainGrid.classList.add('hidden');

    try {
      const url = `https://api.rawg.io/api/games?key=${API_KEY}&page_size=24&ordering=-rating&metacritic=70,100`;
      const res  = await fetch(url);
      if (!res.ok) throw new Error('status ' + res.status);
      const data = await res.json();

      allGames = data.results.map(g => ({
        id:       g.id,
        title:    g.name,
        rating:   g.rating,
        released: g.released,
        image:    g.background_image || 'https://placehold.co/460x215/0d0d1f/00f5ff?text=NO+IMAGE',
        genres:   g.genres?.map(x => x.name).join(', ') || 'Sin género',
      }));

      loadingState.classList.add('hidden');
      mainGrid.classList.remove('hidden');
      renderGames(allGames);
      statStatus.textContent   = 'ONLINE';
      statStatus.style.color   = '#39ff14';
      statStatus.style.textShadow = '0 0 8px #39ff14';

    } catch (err) {
      console.error('RAWG fetch error:', err);
      loadingState.classList.add('hidden');
      errorState.classList.remove('hidden');
      statStatus.textContent = 'ERROR';
      statStatus.style.color = '#ff2d78';
    }
  }

  retryBtn.addEventListener('click', loadGames);
  loadGames();

  searchInput.addEventListener('input', () => {
    const term = searchInput.value.trim().toLowerCase();
    const filtered = term
      ? allGames.filter(g => g.title.toLowerCase().includes(term) || g.genres.toLowerCase().includes(term))
      : allGames;
    renderGames(filtered);
  });

  async function openModal(gameId) {
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
    modalContent.innerHTML = '<p class="pixel-blink" style="text-align:center;padding:3rem">CARGANDO...</p>';

    try {
      const res = await fetch(`https://api.rawg.io/api/games/${gameId}?key=${API_KEY}`);
      if (!res.ok) throw new Error();
      const g = await res.json();

      const desc       = g.description_raw ? g.description_raw.slice(0, 400) + '...' : 'Sin descripción.';
      const color      = scoreColor(g.rating);
      const platforms  = g.platforms?.slice(0, 5).map(p => p.platform.name).join(' · ') || '—';
      const devs       = g.developers?.map(d => d.name).join(', ') || '—';
      const publishers = g.publishers?.map(p => p.name).join(', ') || '—';
      const tags       = g.tags?.slice(0, 8).map(t => `<span style="font-size:.75rem;padding:3px 10px;border:1px solid var(--border);border-radius:3px;color:var(--muted)">${t.name}</span>`).join('') || '';

      modalContent.innerHTML = `
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem">
          <img src="${g.background_image || ''}" alt="${g.name}" style="width:100%;aspect-ratio:16/9;object-fit:cover;border-radius:4px;border:1px solid var(--border)" />
          <div style="display:flex;flex-direction:column;gap:10px">
            <h2 style="font-size:1.4rem;font-weight:700;color:var(--neon-cyan);text-shadow:0 0 12px rgba(0,245,255,.5);line-height:1.2">${g.name}</h2>
            <div style="font-family:var(--font-pixel);font-size:1rem;color:${color};text-shadow:0 0 10px ${color}">
              ★ ${g.rating?.toFixed(1) || '?'} / 5
              ${g.metacritic ? `<span style="margin-left:10px;font-size:.55rem;color:#fff;background:#333;padding:3px 8px;border-radius:3px">${g.metacritic} MC</span>` : ''}
            </div>
            <div style="font-size:.82rem;color:var(--muted);line-height:2">
              <b style="color:var(--text)">Lanzamiento:</b> ${g.released || '—'}<br>
              <b style="color:var(--text)">Géneros:</b> ${g.genres?.map(x => x.name).join(', ') || '—'}<br>
              <b style="color:var(--text)">Tiempo:</b> ${g.playtime ? g.playtime + 'h promedio' : '—'}<br>
              <b style="color:var(--text)">Dev:</b> ${devs}<br>
              <b style="color:var(--text)">Publisher:</b> ${publishers}
            </div>
          </div>
        </div>
        <p style="font-family:var(--font-pixel);font-size:.5rem;color:var(--neon-pink);letter-spacing:2px;border-bottom:1px solid var(--border);padding-bottom:6px;margin-bottom:10px">// DESCRIPCIÓN</p>
        <p style="font-size:.9rem;color:#aaa;line-height:1.7;margin-bottom:1.2rem">${desc}</p>
        ${tags ? `
          <p style="font-family:var(--font-pixel);font-size:.5rem;color:var(--neon-pink);letter-spacing:2px;border-bottom:1px solid var(--border);padding-bottom:6px;margin-bottom:10px">// TAGS</p>
          <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:1.2rem">${tags}</div>
        ` : ''}
        <p style="font-family:var(--font-pixel);font-size:.5rem;color:var(--neon-pink);letter-spacing:2px;border-bottom:1px solid var(--border);padding-bottom:6px;margin-bottom:10px">// PLATAFORMAS</p>
        <p style="font-size:.8rem;color:var(--muted)">${platforms}</p>
      `;
    } catch {
      modalContent.innerHTML = `<p class="pixel-blink" style="color:var(--neon-pink);text-align:center;padding:3rem">ERROR AL CARGAR</p>`;
    }
  }

  function closeModal() {
    modal.classList.remove('open');
    document.body.style.overflow = '';
  }

  modalClose.addEventListener('click', closeModal);
  modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
